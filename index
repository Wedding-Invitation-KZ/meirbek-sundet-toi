<!DOCTYPE html>
<html lang="kk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Мейірбек — Сүндет Той</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,400&family=Great+Vibes&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #b8922a;
    --gold-light: #d4a84b;
    --gold-pale: #f5e6c8;
    --gold-soft: #eedcb0;
    --red: #b5333a;
    --navy: #1a3060;
    --white: #fffdf8;
    --cream: #faf4e8;
    --text: #1a1a1a;
    --text-muted: #6b5c3e;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: var(--white);
    color: var(--text);
    font-family: 'Cormorant Garamond', serif;
    overflow-x: hidden;
  }

  /* ===== MUSIC PLAYER ===== */
  .music-player {
    position: fixed; bottom: 20px; right: 16px; z-index: 1000;
    display: flex; align-items: center; gap: 8px;
    background: var(--white);
    border: 1.5px solid var(--gold-light);
    border-radius: 50px; padding: 9px 16px;
    box-shadow: 0 4px 20px rgba(184,146,42,0.18);
    cursor: pointer; transition: all 0.3s;
  }
  .music-player:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(184,146,42,0.28); }
  .music-icon { font-size:1.2rem; animation: spin 4s linear infinite; display: inline-block; }
  .music-icon.paused { animation-play-state: paused; }
  @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
  .music-label { font-size: 0.75rem; color: var(--gold); letter-spacing: 1.5px; }
  .music-bars { display:flex; gap:3px; align-items:flex-end; height:14px; }
  .music-bars span { display:block; width:3px; background:var(--gold); border-radius:2px; animation: bar var(--s,0.8s) ease-in-out infinite alternate; }
  .music-bars span:nth-child(1){--s:0.6s;height:5px}
  .music-bars span:nth-child(2){--s:0.8s;height:11px}
  .music-bars span:nth-child(3){--s:0.5s;height:7px}
  .music-bars span:nth-child(4){--s:0.9s;height:13px}
  .music-bars.paused span { animation-play-state: paused; }
  @keyframes bar { from{transform:scaleY(0.3)} to{transform:scaleY(1)} }

  /* ===== KAZAKH ORNAMENT SVG PATTERNS ===== */
  .ornament-row {
    display: flex; align-items: center; justify-content: center;
    gap: 10px; margin: 16px 0;
  }
  .ornament-row .line {
    height: 1px; flex: 1; max-width: 120px;
    background: linear-gradient(90deg, transparent, var(--gold-light), transparent);
  }
  .ornament-row .gul { color: var(--gold); font-size: 1.1rem; }

  /* ===== HERO ===== */
  .hero {
    min-height: 100vh;
    background: var(--white);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    padding: 70px 20px 90px;
    border-bottom: 2px solid var(--gold-soft);
  }
  /* Қазақи ою — SVG background */
  .hero-bg-pattern {
    position: absolute; inset: 0; pointer-events: none;
    opacity: 0.07;
    background-image: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%23b8922a' stroke-width='1'%3E%3Cpath d='M40 5 L55 20 L40 35 L25 20Z'/%3E%3Cpath d='M40 45 L55 60 L40 75 L25 60Z'/%3E%3Cpath d='M5 40 L20 25 L35 40 L20 55Z'/%3E%3Cpath d='M45 40 L60 25 L75 40 L60 55Z'/%3E%3Ccircle cx='40' cy='40' r='4'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 80px 80px;
  }
  /* Бұрышты ою өрнектер */
  .corner-ornament {
    position: absolute; width: 120px; height: 120px; opacity: 0.5;
  }
  .corner-ornament.tl { top: 0; left: 0; }
  .corner-ornament.tr { top: 0; right: 0; transform: scaleX(-1); }
  .corner-ornament.bl { bottom: 0; left: 0; transform: scaleY(-1); }
  .corner-ornament.br { bottom: 0; right: 0; transform: scale(-1,-1); }

  .hero-inner { text-align: center; z-index: 2; }
  .hero-top-badge {
    display: inline-block;
    border: 1.5px solid var(--gold-light);
    border-radius: 4px;
    padding: 6px 22px;
    font-size: 0.8rem; letter-spacing: 5px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 24px;
  }
  .main-name {
    font-family: 'Great Vibes', cursive;
    font-size: clamp(4.5rem,16vw,8rem);
    color: var(--navy); line-height: 1;
    margin-bottom: 8px;
  }
  .event-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.2rem,4.5vw,1.8rem);
    color: var(--gold); letter-spacing: 5px; font-style: italic;
    margin-bottom: 28px;
  }
  .date-badge {
    display: inline-block;
    background: var(--gold-pale);
    border: 1.5px solid var(--gold-light);
    border-radius: 50px;
    padding: 10px 32px;
    color: var(--gold); font-size: 1.05rem; letter-spacing: 3px;
    margin-bottom: 0;
  }
  .scroll-hint {
    position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
    color: var(--gold-light); animation: bounce 2s ease infinite; font-size: 1.4rem;
  }
  @keyframes bounce {
    0%,100%{transform:translateX(-50%) translateY(0)}
    50%{transform:translateX(-50%) translateY(8px)}
  }

  /* ===== INVITE SECTION ===== */
  .invite-section {
    background: var(--cream);
    padding: 70px 24px; text-align: center; position: relative; overflow: hidden;
    border-bottom: 1px solid var(--gold-soft);
  }
  .invite-section .oy-border {
    position: absolute; left: 0; right: 0; height: 18px; opacity: 0.35;
    background-image: url("data:image/svg+xml,%3Csvg width='40' height='18' viewBox='0 0 40 18' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 9 Q5 0 10 9 Q15 18 20 9 Q25 0 30 9 Q35 18 40 9' fill='none' stroke='%23b8922a' stroke-width='1.5'/%3E%3C/svg%3E");
    background-repeat: repeat-x;
  }
  .invite-section .oy-border.top { top: 0; }
  .invite-section .oy-border.bottom { bottom: 0; }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem,5vw,2.4rem); color: var(--navy); margin-bottom: 8px;
  }
  .section-subtitle {
    color: var(--gold); letter-spacing: 4px; font-size: 0.85rem;
    text-transform: uppercase; margin-bottom: 36px;
  }
  .invite-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem,3vw,1.3rem); color: var(--text-muted);
    line-height: 2; max-width: 580px; margin: 0 auto 18px; font-style: italic;
  }

  /* ===== CALENDAR ===== */
  .calendar-section {
    background: var(--white); padding: 60px 20px; text-align: center;
  }
  .calendar-wrap {
    display: inline-block;
    background: var(--white);
    border: 1.5px solid var(--gold-soft);
    border-radius: 20px; overflow: hidden;
    box-shadow: 0 10px 40px rgba(184,146,42,0.1);
    max-width: 360px; width: 100%;
  }
  .cal-header {
    background: var(--gold-pale);
    border-bottom: 1.5px solid var(--gold-soft);
    padding: 20px; text-align: center;
  }
  .cal-month { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--navy); letter-spacing: 4px; margin-bottom: 2px; }
  .cal-year { font-size: 0.9rem; color: var(--gold); letter-spacing: 3px; }
  .cal-grid { display: grid; grid-template-columns: repeat(7,1fr); }
  .cal-day-name {
    padding: 10px 2px 8px; font-size: 0.72rem; color: var(--gold);
    letter-spacing: 1px; text-transform: uppercase; font-weight: 600;
    border-bottom: 1px solid var(--gold-soft);
    background: rgba(245,230,200,0.3);
  }
  .cal-day {
    padding: 9px 2px; font-size: 0.95rem; color: var(--text);
    cursor: default; text-align: center; position: relative;
  }
  .cal-day.empty { color: transparent; }
  .cal-day.weekend { color: var(--text-muted); opacity: 0.5; }

  /* 25-інің жүрекпен қоршалуы — нақты */
  .cal-day.highlight {
    z-index: 1;
    color: var(--red) !important;
    font-weight: 700;
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
  }
  .cal-day.highlight .day-inner {
    display: inline-flex;
    align-items: center; justify-content: center;
    width: 34px; height: 34px;
    border-radius: 50%;
    background: rgba(181,51,58,0.1);
    border: 2px solid rgba(181,51,58,0.4);
    position: relative;
  }
  .cal-day.highlight .day-inner::after {
    content: '♥';
    position: absolute;
    top: -11px; left: 50%; transform: translateX(-50%);
    font-size: 0.65rem;
    color: var(--red);
    opacity: 0.7;
  }

  /* ===== COUNTDOWN ===== */
  .countdown-section {
    background: var(--cream); padding: 60px 16px; text-align: center;
    position: relative; overflow: hidden;
    border-top: 1px solid var(--gold-soft);
    border-bottom: 1px solid var(--gold-soft);
  }
  .countdown-section::before {
    content: ''; position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 10 L40 30 L30 50 L20 30Z' fill='none' stroke='%23b8922a' stroke-width='0.8' opacity='0.15'/%3E%3C/svg%3E");
    background-size: 60px 60px; pointer-events: none;
  }
  .countdown-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    max-width: 400px;
    margin: 0 auto;
    position: relative;
  }
  .countdown-box {
    background: var(--white);
    border: 1.5px solid var(--gold-soft);
    border-radius: 14px;
    padding: 16px 6px;
    box-shadow: 0 4px 16px rgba(184,146,42,0.1);
    transition: transform 0.3s;
  }
  .countdown-box:hover { transform: translateY(-3px); }
  .countdown-num {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 7vw, 2.6rem);
    color: var(--navy); line-height: 1;
    display: block;
  }
  .countdown-label {
    color: var(--gold); font-size: 0.7rem; letter-spacing: 2px;
    text-transform: uppercase; margin-top: 5px; display: block;
  }

  /* ===== VENUE ===== */
  .venue-section { background: var(--white); padding: 60px 20px; text-align: center; }
  .venue-card {
    max-width: 520px; margin: 0 auto;
    background: var(--cream);
    border: 1.5px solid var(--gold-soft);
    border-radius: 20px; padding: 36px 28px;
    box-shadow: 0 10px 40px rgba(184,146,42,0.1);
    position: relative; overflow: hidden;
  }
  .venue-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
  }
  /* Ою өрнек venue картаның бұрышында */
  .venue-card::after {
    content: ''; position: absolute; bottom: 0; right: 0;
    width: 80px; height: 80px; opacity: 0.1;
    background-image: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M80 0 L80 80 L0 80' fill='none' stroke='%23b8922a' stroke-width='8'/%3E%3Cpath d='M80 20 L80 80 L20 80' fill='none' stroke='%23b8922a' stroke-width='3'/%3E%3C/svg%3E");
  }
  .venue-icon { font-size: 2.2rem; margin-bottom: 10px; }
  .venue-name { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--navy); margin-bottom: 10px; }
  .venue-address { font-size: 1.1rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 24px; }
  .map-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--navy); color: #fff; text-decoration: none;
    padding: 13px 30px; border-radius: 50px;
    font-size: 1rem; letter-spacing: 1px;
    transition: all 0.3s; box-shadow: 0 4px 16px rgba(26,48,96,0.2);
    margin-bottom: 20px;
  }
  .map-btn:hover { background: var(--gold); color: var(--navy); transform: translateY(-2px); }
  .map-embed { border-radius: 12px; overflow: hidden; border: 1.5px solid var(--gold-soft); margin-bottom: 20px; }
  .map-embed iframe { width: 100%; height: 220px; display: block; border: none; }
  .venue-photo {
    border-radius: 12px; overflow: hidden; border: 1.5px solid var(--gold-soft);
    height: 180px;
    background: linear-gradient(135deg, var(--gold-pale) 0%, #e8d5a0 100%);
    display: flex; align-items: center; justify-content: center;
  }
  .venue-photo-inner { text-align: center; color: var(--navy); }
  .venue-photo-inner .big-icon { font-size: 2.5rem; display: block; margin-bottom: 8px; }
  .venue-photo-inner p { font-size: 1.05rem; font-family: 'Playfair Display', serif; font-weight: 700; letter-spacing: 2px; }

  /* ===== TIME SECTION ===== */
  .time-section {
    background: var(--navy); padding: 60px 20px; text-align: center;
    position: relative; overflow: hidden;
  }
  .time-section::before {
    content: ''; position: absolute; inset: 0; opacity: 0.06;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%23d4a84b' stroke-width='1'%3E%3Cpath d='M30 5 L55 30 L30 55 L5 30Z'/%3E%3Cpath d='M30 15 L45 30 L30 45 L15 30Z'/%3E%3Ccircle cx='30' cy='30' r='4'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 60px 60px;
  }
  .time-section .section-title { color: var(--gold-pale); margin-bottom: 4px; }
  .time-display {
    font-family: 'Great Vibes', cursive;
    font-size: clamp(3.5rem, 14vw, 6rem);
    color: var(--gold-light);
    margin: 10px 0 8px;
  }
  .time-label { font-size: 1rem; letter-spacing: 5px; text-transform: uppercase; color: rgba(212,168,75,0.6); }

  /* ===== HOSTS — БІРІКТІРІЛГЕН ===== */
  .hosts-section {
    background: var(--cream);
    padding: 60px 20px; text-align: center;
    border-top: 1px solid var(--gold-soft);
  }
  .hosts-unified {
    max-width: 500px; margin: 0 auto;
    background: var(--white);
    border: 1.5px solid var(--gold-soft);
    border-radius: 20px; overflow: hidden;
    box-shadow: 0 10px 40px rgba(184,146,42,0.1);
  }
  .hosts-unified-header {
    background: var(--gold-pale);
    border-bottom: 1.5px solid var(--gold-soft);
    padding: 16px 20px;
    display: flex; align-items: center; justify-content: center; gap: 12px;
  }
  .hosts-unified-header .oyu-icon { font-size: 1.4rem; color: var(--gold); }
  .hosts-unified-header .title-text {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem; color: var(--navy); font-style: italic; letter-spacing: 2px;
  }
  .host-row {
    padding: 20px 28px 18px;
    position: relative;
  }
  .host-row + .host-row {
    border-top: 1px dashed var(--gold-soft);
  }
  .host-role {
    font-size: 0.72rem; letter-spacing: 4px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 8px; font-weight: 600;
  }
  .host-names {
    font-family: 'Playfair Display', serif;
    font-size: 1.45rem; color: var(--navy); font-style: italic;
  }
  .host-sep { color: var(--gold-light); margin: 0 10px; font-style: normal; }
  /* Ою өрнек разделитель */
  .hosts-divider {
    display: flex; align-items: center; gap: 10px;
    padding: 4px 28px;
    background: rgba(245,230,200,0.3);
  }
  .hosts-divider .hl { flex: 1; height: 1px; background: var(--gold-soft); }
  .hosts-divider .hm { color: var(--gold-light); font-size: 0.9rem; }

  /* ===== CLOSING ===== */
  .closing-section {
    background: var(--white); padding: 70px 24px; text-align: center;
    position: relative; overflow: hidden;
    border-top: 2px solid var(--gold-soft);
  }
  .closing-section .oy-border {
    position: absolute; left: 0; right: 0; height: 18px; opacity: 0.3;
    background-image: url("data:image/svg+xml,%3Csvg width='40' height='18' viewBox='0 0 40 18' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 9 Q5 0 10 9 Q15 18 20 9 Q25 0 30 9 Q35 18 40 9' fill='none' stroke='%23b8922a' stroke-width='1.5'/%3E%3C/svg%3E");
    background-repeat: repeat-x;
  }
  .closing-section .oy-border.top { top: 0; }
  .closing-section .oy-border.bottom { bottom: 0; }
  .closing-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.15rem,3.5vw,1.5rem);
    color: var(--text-muted); line-height: 2.1;
    max-width: 580px; margin: 0 auto; font-style: italic;
  }

  /* ===== FOOTER ===== */
  footer {
    background: var(--cream);
    border-top: 1.5px solid var(--gold-soft);
    padding: 40px 20px; text-align: center;
    color: var(--text-muted); font-size: 0.9rem;
  }
  footer .footer-name {
    font-family: 'Great Vibes', cursive;
    font-size: 2.5rem; color: var(--navy); margin-bottom: 10px; display: block;
  }

  /* ===== ANIMATIONS ===== */
  @keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
  @keyframes fadeDown { from{opacity:0;transform:translateY(-16px)} to{opacity:1;transform:translateY(0)} }
  .reveal { opacity:0; transform:translateY(24px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity:1; transform:none; }
  .hero-inner { animation: fadeUp 1s ease both 0.2s; }
</style>
</head>
<body>

<audio id="bgMusic" loop preload="auto" autoplay playsinline>
  <source id="audioSrc" type="audio/mp3">
</audio>

<div class="music-player" id="musicPlayer" onclick="toggleMusic()">
  <span class="music-icon" id="musicIcon">🎵</span>
  <span class="music-label">Сүндет той</span>
  <div class="music-bars" id="musicBars">
    <span></span><span></span><span></span><span></span>
  </div>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg-pattern"></div>

  <!-- Бұрышты ою өрнектер -->
  <svg class="corner-ornament tl" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0 0 L120 0 L0 120Z" fill="none" stroke="#b8922a" stroke-width="1" opacity="0.4"/>
    <path d="M0 0 L70 0 L0 70Z" fill="none" stroke="#b8922a" stroke-width="1" opacity="0.5"/>
    <path d="M10 10 Q30 0 50 10 Q70 20 90 10" stroke="#b8922a" stroke-width="1" fill="none" opacity="0.4"/>
    <path d="M0 30 Q10 50 0 70" stroke="#b8922a" stroke-width="1" fill="none" opacity="0.4"/>
    <path d="M30 0 Q30 20 20 30 Q10 40 20 50" stroke="#b8922a" stroke-width="1" fill="none" opacity="0.35"/>
    <path d="M5 5 L25 5 L25 25 L5 25 Z" stroke="#b8922a" stroke-width="0.8" fill="none" opacity="0.3"/>
    <circle cx="15" cy="15" r="4" stroke="#b8922a" stroke-width="0.8" fill="none" opacity="0.4"/>
  </svg>
  <svg class="corner-ornament tr" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0 0 L120 0 L0 120Z" fill="none" stroke="#b8922a" stroke-width="1" opacity="0.4"/>
    <path d="M0 0 L70 0 L0 70Z" fill="none" stroke="#b8922a" stroke-width="1" opacity="0.5"/>
    <path d="M10 10 Q30 0 50 10 Q70 20 90 10" stroke="#b8922a" stroke-width="1" fill="none" opacity="0.4"/>
    <path d="M0 30 Q10 50 0 70" stroke="#b8922a" stroke-width="1" fill="none" opacity="0.4"/>
    <path d="M30 0 Q30 20 20 30 Q10 40 20 50" stroke="#b8922a" stroke-width="1" fill="none" opacity="0.35"/>
    <circle cx="15" cy="15" r="4" stroke="#b8922a" stroke-width="0.8" fill="none" opacity="0.4"/>
  </svg>
  <svg class="corner-ornament bl" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0 0 L120 0 L0 120Z" fill="none" stroke="#b8922a" stroke-width="1" opacity="0.4"/>
    <path d="M0 0 L70 0 L0 70Z" fill="none" stroke="#b8922a" stroke-width="1" opacity="0.5"/>
    <path d="M10 10 Q30 0 50 10 Q70 20 90 10" stroke="#b8922a" stroke-width="1" fill="none" opacity="0.4"/>
    <path d="M0 30 Q10 50 0 70" stroke="#b8922a" stroke-width="1" fill="none" opacity="0.4"/>
    <path d="M30 0 Q30 20 20 30 Q10 40 20 50" stroke="#b8922a" stroke-width="1" fill="none" opacity="0.35"/>
    <circle cx="15" cy="15" r="4" stroke="#b8922a" stroke-width="0.8" fill="none" opacity="0.4"/>
  </svg>
  <svg class="corner-ornament br" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0 0 L120 0 L0 120Z" fill="none" stroke="#b8922a" stroke-width="1" opacity="0.4"/>
