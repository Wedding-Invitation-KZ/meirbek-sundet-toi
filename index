<script>
document.addEventListener('DOMContentLoaded', () => {
  const audioEl = document.getElementById('bgMusic');
  const audioSrc = document.getElementById('audioSrc');
  if (audioSrc && audioEl) { audioSrc.src = 'music.mp3'; audioEl.load(); }
});

function toggleMusic() {
  const audioEl = document.getElementById('bgMusic');
  const musicIcon = document.getElementById('musicIcon');
  const musicBars = document.getElementById('musicBars');
  if (!audioEl) return;
  if (audioEl.paused) {
    audioEl.play().catch(e => console.log(e));
    musicIcon && musicIcon.classList.remove('paused');
    musicBars && musicBars.classList.remove('paused');
  } else {
    audioEl.pause();
    musicIcon && musicIcon.classList.add('paused');
    musicBars && musicBars.classList.add('paused');
  }
}

document.addEventListener('click', function() {
  const audioEl = document.getElementById('bgMusic');
  if (audioEl && audioEl.paused) {
    audioEl.play().then(() => {
      document.getElementById('musicIcon')?.classList.remove('paused');
      document.getElementById('musicBars')?.classList.remove('paused');
    }).catch(() => {});
  }
}, { once: true });

// CALENDAR
const grid = document.getElementById('cal-grid');
const dayNames = ['Дс','Сс','Ср','Бс','Жм','Сб','Жс'];
dayNames.forEach(name => {
  const el = document.createElement('div');
  el.className = 'cal-day-name';
  el.innerText = name;
  grid.appendChild(el);
});

const startDayOfWeek = 2;
for (let i = 0; i < startDayOfWeek; i++) {
  const el = document.createElement('div');
  el.className = 'cal-day empty';
  el.innerHTML = '&nbsp;';
  grid.appendChild(el);
}

for (let d = 1; d <= 31; d++) {
  const el = document.createElement('div');
  el.className = 'cal-day';
  const dayOfWeek = (startDayOfWeek + d - 1) % 7;
  if (dayOfWeek === 5 || dayOfWeek === 6) el.classList.add('weekend');
  if (d === 25) {
    el.classList.add('highlight');
    el.innerHTML = '<span class="day-inner">25</span>';
  } else {
    el.innerText = d;
  }
  grid.appendChild(el);
}

// COUNTDOWN
const targetDate = new Date('July 25, 2026 19:00:00').getTime();
function pad(n) { return n < 10 ? '0' + n : n; }
function updateCountdown() {
  const diff = targetDate - Date.now();
  if (diff <= 0) {
    ['cd-days','cd-hours','cd-mins','cd-secs'].forEach(id => document.getElementById(id).innerText = '00');
    return;
  }
  document.getElementById('cd-days').innerText = pad(Math.floor(diff / 86400000));
  document.getElementById('cd-hours').innerText = pad(Math.floor((diff % 86400000) / 3600000));
  document.getElementById('cd-mins').innerText = pad(Math.floor((diff % 3600000) / 60000));
  document.getElementById('cd-secs').innerText = pad(Math.floor((diff % 60000) / 1000));
}
setInterval(updateCountdown, 1000);
updateCountdown();

// SCROLL REVEAL
const revealEls = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
revealEls.forEach(el => observer.observe(el));
</script>
